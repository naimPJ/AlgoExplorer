PORT=3001
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=ibudata
# Only needed for hosts that enforce SSL (e.g. DigitalOcean Managed MySQL).
# Paste the CA cert contents; if set as a single-line env var, escape newlines as \n.
DB_CA_CERT=

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
